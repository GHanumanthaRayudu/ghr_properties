<% content_for :title, "Browse Properties - GHR Properties" %>

<div class="bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Browse Properties</h1>
      <p class="text-lg text-gray-600">Find your perfect property from our verified listings</p>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-md p-6 mb-8">
      <%= form_with url: properties_path, method: :get, class: "space-y-6" do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <!-- Status Filter -->
          <div>
            <label class="form-label flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Status
            </label>
            <%= f.select :status, 
                options_for_select([
                  ['Available', 'available'],
                  ['Sold', 'sold'],
                  ['Ongoing', 'ongoing'],
                  ['Rented', 'rented']
                ], params[:status]),
                { include_blank: 'All' },
                class: "form-input" %>
          </div>
          
          <!-- Property Type Filter -->
          <div>
            <label class="form-label flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              Property Type
            </label>
            <%= f.select :property_type,
                options_for_select([
                  ['House', 'house'],
                  ['Apartment', 'apartment'],
                  ['Condo', 'condo'],
                  ['Land', 'land'],
                  ['Commercial', 'commercial']
                ], params[:property_type]),
                { include_blank: 'All' },
                class: "form-input" %>
          </div>
          
          <!-- Location Filter -->
          <div>
            <label class="form-label flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Location
            </label>
            <%= f.text_field :location, 
                value: params[:location],
                placeholder: "City or State",
                class: "form-input" %>
          </div>
          
          <!-- Price Range -->
          <div>
            <label class="form-label flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Min Price (₹)
            </label>
            <%= f.number_field :min_price, 
                value: params[:min_price],
                placeholder: "50,000",
                class: "form-input" %>
          </div>
        </div>

        <!-- Second Row for Max Price and Bedrooms -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div>
            <label class="form-label flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Max Price (₹)
            </label>
            <%= f.number_field :max_price,
                value: params[:max_price],
                placeholder: "10,000,000",
                class: "form-input" %>
          </div>

          <div class="md:col-span-3 flex items-end gap-3">
            <%= f.submit "🔍 Search Properties", class: "btn btn-primary flex-1" %>
            <%= link_to "Clear All", properties_path, class: "btn btn-secondary" %>
          </div>
        </div>

        <!-- Active Filters Display -->
        <% if params[:status].present? || params[:property_type].present? || params[:location].present? || params[:min_price].present? || params[:max_price].present? %>
          <div class="flex items-center gap-2 pt-4 border-t border-gray-200">
            <span class="text-sm font-medium text-gray-700">Active Filters:</span>
            <div class="flex flex-wrap gap-2">
              <% if params[:status].present? %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                  Status: <%= params[:status].titleize %>
                  <%= link_to "×", properties_path(params.except(:status)), class: "ml-2 text-blue-600 hover:text-blue-800" %>
                </span>
              <% end %>
              <% if params[:property_type].present? %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                  Type: <%= params[:property_type].titleize %>
                  <%= link_to "×", properties_path(params.except(:property_type)), class: "ml-2 text-green-600 hover:text-green-800" %>
                </span>
              <% end %>
              <% if params[:location].present? %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-800">
                  Location: <%= params[:location] %>
                  <%= link_to "×", properties_path(params.except(:location)), class: "ml-2 text-purple-600 hover:text-purple-800" %>
                </span>
              <% end %>
              <% if params[:min_price].present? || params[:max_price].present? %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                  Price: ₹<%= number_with_delimiter(params[:min_price] || 0) %> - ₹<%= number_with_delimiter(params[:max_price] || '∞') %>
                  <%= link_to "×", properties_path(params.except(:min_price, :max_price)), class: "ml-2 text-yellow-600 hover:text-yellow-800" %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Results Count -->
    <div class="mb-6">
      <p class="text-gray-700 font-semibold">
        Showing <%= @properties.count %> properties
      </p>
    </div>

    <!-- Property Grid -->
    <% if @properties.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
        <% @properties.each do |property| %>
          <%= link_to property_path(property), class: "card group" do %>
            <div class="h-56 bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center relative overflow-hidden">
              <span class="text-7xl group-hover:scale-110 transition-transform">
                <%= property.property_type == 'apartment' ? '🏢' : property.property_type == 'villa' ? '🏰' : '🏠' %>
              </span>
              <div class="absolute top-4 right-4">
                <span class="px-3 py-1 <%= property.available? ? 'bg-green-500 text-white' : property.sold? ? 'bg-red-500 text-white' : 'bg-yellow-500 text-white' %> rounded-full text-sm font-bold shadow-lg">
                  <%= property.status.titleize %>
                </span>
              </div>
            </div>
            
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-3 line-clamp-2">
                <%= property.title %>
              </h3>
              
              <div class="space-y-2 text-sm text-gray-600 mb-4">
                <p class="flex items-center">
                  <span class="mr-2">📍</span>
                  <%= property.city %>, <%= property.state %>
                </p>
                
                <p class="flex items-center">
                  <span class="mr-2">🏠</span>
                  <%= property.property_type.titleize %> • 
                  <%= property.bedrooms %> BHK • 
                  <%= property.area %> sq.ft
                </p>
              </div>
              
              <div class="flex justify-between items-center pt-4 border-t">
                <div>
                  <p class="text-sm text-gray-500">Price</p>
                  <p class="text-2xl font-bold text-primary-600">
                    ₹<%= number_with_delimiter(property.price) %>
                  </p>
                </div>
                
                <div class="text-right">
                  <p class="text-sm text-gray-500">Posted by</p>
                  <p class="text-sm font-semibold text-gray-700"><%= property.user.name || 'Owner' %></p>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <!-- Pagination -->
      <div class="flex justify-center">
        <%= paginate @properties %>
      </div>
    <% else %>
      <div class="text-center py-12 bg-white rounded-xl shadow-md">
        <div class="text-6xl mb-4">🔍</div>
        <h3 class="text-2xl font-bold text-gray-900 mb-2">No Properties Found</h3>
        <p class="text-gray-600 mb-6">Try adjusting your filters or search criteria</p>
        <%= link_to "Clear Filters", properties_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

