<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Back Button -->
  <div class="mb-6">
    <% if current_user == @inquiry.property.user %>
      <%= link_to property_inquiries_path(@inquiry.property), class: "text-primary-600 hover:text-primary-700 font-medium inline-flex items-center" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to All Inquiries
      <% end %>
    <% else %>
      <%= link_to @inquiry.property, class: "text-primary-600 hover:text-primary-700 font-medium inline-flex items-center" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Property
      <% end %>
    <% end %>
  </div>

  <!-- Inquiry Card -->
  <div class="bg-white rounded-lg shadow-lg overflow-hidden">
    <!-- Header -->
    <div class="bg-gradient-to-r from-primary-600 to-primary-700 px-6 py-8 text-white">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold mb-2">Inquiry #<%= @inquiry.id %></h1>
          <p class="text-primary-100">
            Submitted <%= time_ago_in_words(@inquiry.created_at) %> ago
          </p>
        </div>
        
        <!-- Status Badge -->
        <% case @inquiry.status %>
        <% when 'pending' %>
          <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
            <span class="w-2 h-2 bg-yellow-400 rounded-full mr-2"></span>
            Pending
          </span>
        <% when 'responded' %>
          <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
            <span class="w-2 h-2 bg-blue-400 rounded-full mr-2"></span>
            Responded
          </span>
        <% when 'closed' %>
          <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-green-100 text-green-800">
            <span class="w-2 h-2 bg-green-400 rounded-full mr-2"></span>
            Closed
          </span>
        <% end %>
      </div>
    </div>

    <!-- Property Info -->
    <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-medium text-gray-500 mb-2">Property</h2>
      <%= link_to @inquiry.property, class: "text-lg font-semibold text-primary-600 hover:text-primary-700" do %>
        <%= @inquiry.property.title %>
      <% end %>
      <p class="text-sm text-gray-600 mt-1">
        <%= @inquiry.property.location %> • 
        <%= number_to_currency(@inquiry.property.price, precision: 0, unit: "₹") %>
      </p>
    </div>

    <!-- Customer Info -->
    <div class="border-b border-gray-200 px-6 py-6">
      <h2 class="text-sm font-medium text-gray-500 mb-4">Customer Information</h2>
      <div class="flex items-center gap-4">
        <div class="bg-primary-100 rounded-full p-3">
          <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-gray-900 text-lg"><%= @inquiry.customer.name %></p>
          <p class="text-gray-600"><%= @inquiry.customer.email %></p>
          <p class="text-sm text-gray-500 mt-1">
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
              Customer
            </span>
          </p>
        </div>
      </div>
    </div>

    <!-- Message -->
    <div class="px-6 py-6">
      <h2 class="text-sm font-medium text-gray-500 mb-4">Message</h2>
      <div class="bg-gray-50 rounded-lg p-6 border-l-4 border-primary-500">
        <p class="text-gray-800 text-lg leading-relaxed whitespace-pre-wrap"><%= @inquiry.message %></p>
      </div>
    </div>

    <!-- Update Status (for property owner) -->
    <% if current_user == @inquiry.property.user %>
      <div class="border-t border-gray-200 bg-gray-50 px-6 py-6">
        <h2 class="text-sm font-medium text-gray-700 mb-4">Update Inquiry Status</h2>
        <%= form_with model: @inquiry, url: inquiry_path(@inquiry), method: :patch, local: true, class: "flex items-center gap-4" do |f| %>
          <%= f.select :status, 
              Inquiry.statuses.keys.map { |s| [s.titleize, s] }, 
              { selected: @inquiry.status },
              class: "flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          <%= f.submit "Update Status", class: "btn btn-primary px-8" %>
        <% end %>
        
        <div class="mt-4 bg-blue-50 rounded-lg p-4">
          <p class="text-sm text-blue-800">
            <svg class="inline w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <strong>Status Guide:</strong> 
            Pending = New inquiry | 
            Responded = You've contacted the customer | 
            Closed = Inquiry resolved
          </p>
        </div>
      </div>
    <% end %>

    <!-- Timeline -->
    <div class="border-t border-gray-200 px-6 py-6">
      <h2 class="text-sm font-medium text-gray-500 mb-4">Timeline</h2>
      <div class="space-y-4">
        <div class="flex items-start gap-3">
          <div class="bg-green-100 rounded-full p-2 mt-1">
            <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-900">Inquiry Created</p>
            <p class="text-sm text-gray-500"><%= @inquiry.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
          </div>
        </div>
        
        <% if @inquiry.updated_at != @inquiry.created_at %>
          <div class="flex items-start gap-3">
            <div class="bg-blue-100 rounded-full p-2 mt-1">
              <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-900">Last Updated</p>
              <p class="text-sm text-gray-500"><%= @inquiry.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>


