<% content_for :title, "My Dashboard - GHR Properties" %>

<div class="bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Welcome Header -->
    <div class="mb-8">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-2">
        Welcome back, <%= current_user.name || current_user.email %>! 👋
      </h1>
      <p class="text-lg text-gray-600">Manage your properties and track your activity</p>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-medium">My Properties</p>
            <p class="text-3xl font-bold text-gray-900"><%= current_user.properties.count %></p>
          </div>
          <div class="text-4xl">🏠</div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-medium">Messages</p>
            <p class="text-3xl font-bold text-gray-900"><%= current_user.received_messages.count %></p>
          </div>
          <div class="text-4xl">💬</div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-medium">Reviews</p>
            <p class="text-3xl font-bold text-gray-900"><%= current_user.reviews.count %></p>
          </div>
          <div class="text-4xl">⭐</div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-medium">Active Listings</p>
            <p class="text-3xl font-bold text-gray-900"><%= current_user.properties.count %></p>
          </div>
          <div class="text-4xl">📊</div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- My Properties Section -->
      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-900">My Properties</h2>
          <%= link_to "View All", properties_path(user_id: current_user.id), class: "text-primary-600 hover:text-primary-700 font-semibold" %>
        </div>

        <% if @my_properties.any? %>
          <div class="space-y-4">
            <% @my_properties.each do |property| %>
              <%= link_to property_path(property), class: "block p-4 border border-gray-200 rounded-lg hover:border-primary-300 hover:shadow-md transition-all" do %>
                <div class="flex justify-between items-start">
                  <div class="flex-1">
                    <h3 class="font-bold text-gray-900 mb-1"><%= property.title %></h3>
                    <p class="text-sm text-gray-600 mb-2">
                      <%= property.city %>, <%= property.state %>
                    </p>
                    <div class="flex items-center space-x-3 text-sm">
                      <span class="text-primary-600 font-semibold">
                        ₹<%= number_with_delimiter(property.price) %>/<%= property.listing_type == 'rent' ? 'mo' : 'total' %>
                      </span>
                      <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded">
                        <%= property.bedrooms %> BHK
                      </span>
                    </div>
                  </div>
                  <div class="text-3xl ml-4">
                    <%= property.property_type == 'apartment' ? '🏢' : '🏠' %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>

          <div class="mt-6">
            <%= link_to "Post New Property", new_property_path, class: "btn btn-primary w-full" %>
          </div>
        <% else %>
          <div class="text-center py-12">
            <div class="text-6xl mb-4">🏠</div>
            <p class="text-gray-600 mb-4">You haven't posted any properties yet</p>
            <%= link_to "Post Your First Property", new_property_path, class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>

      <!-- Recent Messages Section -->
      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-900">Recent Messages</h2>
          <%= link_to "View All", "#", class: "text-primary-600 hover:text-primary-700 font-semibold" %>
        </div>

        <% if @received_messages.any? %>
          <div class="space-y-4">
            <% @received_messages.each do |message| %>
              <div class="p-4 border border-gray-200 rounded-lg">
                <div class="flex items-start">
                  <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center mr-3">
                    <span class="text-xl">👤</span>
                  </div>
                  <div class="flex-1">
                    <div class="flex justify-between items-start mb-1">
                      <p class="font-semibold text-gray-900"><%= message.sender.name || message.sender.email %></p>
                      <span class="text-xs text-gray-500"><%= time_ago_in_words(message.created_at) %> ago</span>
                    </div>
                    <p class="text-sm text-gray-600 line-clamp-2"><%= message.content %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-12">
            <div class="text-6xl mb-4">💬</div>
            <p class="text-gray-600">No messages yet</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Reviews -->
    <div class="bg-white rounded-xl shadow-md p-6 mt-8">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-900">My Reviews</h2>
        <%= link_to "View All", "#", class: "text-primary-600 hover:text-primary-700 font-semibold" %>
      </div>

      <% if @my_reviews.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @my_reviews.each do |review| %>
            <div class="p-4 border border-gray-200 rounded-lg">
              <div class="flex justify-between items-start mb-2">
                <div class="flex items-center">
                  <span class="text-yellow-400 mr-1">⭐</span>
                  <span class="font-bold"><%= review.rating %>/5</span>
                </div>
                <span class="text-xs text-gray-500"><%= review.created_at.strftime("%b %d") %></span>
              </div>
              <p class="text-sm text-gray-700 mb-2 line-clamp-2"><%= review.comment %></p>
              <p class="text-xs text-gray-500">
                On: <%= link_to review.property.title, property_path(review.property), class: "text-primary-600 hover:underline" %>
              </p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-12">
          <div class="text-6xl mb-4">⭐</div>
          <p class="text-gray-600">You haven't written any reviews yet</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

