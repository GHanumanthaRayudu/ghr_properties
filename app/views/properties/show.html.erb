<% content_for :title, "#{@property.title} - GHR Properties" %>

<div class="bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Back Button -->
    <div class="mb-6">
      <%= link_to "← Back to Properties", properties_path, class: "text-primary-600 hover:text-primary-700 font-semibold" %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Property Images -->
        <div class="bg-white rounded-xl shadow-md overflow-hidden mb-6">
          <div class="h-96 bg-gradient-to-br from-gray-200 to-gray-400 flex items-center justify-center">
            <span class="text-9xl">
              <%= @property.property_type == 'apartment' ? '🏢' : @property.property_type == 'villa' ? '🏰' : '🏠' %>
            </span>
          </div>
        </div>

        <!-- Property Details -->
        <div class="bg-white rounded-xl shadow-md p-8 mb-6">
          <div class="flex justify-between items-start mb-6">
            <div>
              <h1 class="text-3xl font-extrabold text-gray-900 mb-2"><%= @property.title %></h1>
              <p class="text-xl text-gray-600 flex items-center">
                <span class="mr-2">📍</span>
                <%= @property.address %>, <%= @property.city %>, <%= @property.state %> - <%= @property.pincode %>
              </p>
            </div>
            <span class="px-4 py-2 <%= @property.available? ? 'bg-green-100 text-green-800' : @property.sold? ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' %> rounded-full font-bold">
              <%= @property.status.titleize %>
            </span>
          </div>

          <!-- Key Features -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8 pb-8 border-b">
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <div class="text-3xl mb-2">🛏️</div>
              <p class="text-sm text-gray-600">Bedrooms</p>
              <p class="text-xl font-bold text-gray-900"><%= @property.bedrooms %></p>
            </div>
            
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <div class="text-3xl mb-2">🚿</div>
              <p class="text-sm text-gray-600">Bathrooms</p>
              <p class="text-xl font-bold text-gray-900"><%= @property.bathrooms %></p>
            </div>
            
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <div class="text-3xl mb-2">📐</div>
              <p class="text-sm text-gray-600">Area</p>
              <p class="text-xl font-bold text-gray-900"><%= @property.area %> sq.ft</p>
            </div>
            
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <div class="text-3xl mb-2">🏗️</div>
              <p class="text-sm text-gray-600">Type</p>
              <p class="text-xl font-bold text-gray-900"><%= @property.property_type.titleize %></p>
            </div>
          </div>

          <!-- Description -->
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Description</h2>
            <p class="text-gray-700 leading-relaxed whitespace-pre-line"><%= @property.description %></p>
          </div>

          <!-- Amenities -->
          <% if @property.amenities.present? %>
            <div class="mb-8">
              <h2 class="text-2xl font-bold text-gray-900 mb-4">Amenities</h2>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                <% @property.amenities.split(',').each do |amenity| %>
                  <div class="flex items-center text-gray-700">
                    <span class="mr-2">✓</span>
                    <%= amenity.strip %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <!-- Availability -->
          <div class="bg-blue-50 rounded-lg p-4">
            <p class="text-gray-700">
              <span class="font-semibold">Available from:</span>
              <%= @property.available_from.strftime("%B %d, %Y") %>
            </p>
          </div>
        </div>

        <!-- Reviews Section -->
        <div class="bg-white rounded-xl shadow-md p-8">
          <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-bold text-gray-900">Reviews (<%= @reviews.count %>)</h2>
            <% if @property.reviews.any? %>
              <div class="flex items-center">
                <span class="text-yellow-500 text-2xl mr-2">★</span>
                <span class="text-xl font-bold"><%= @property.average_rating %></span>
                <span class="text-gray-500 ml-1">/5</span>
              </div>
            <% end %>
          </div>

          <!-- Add Review Form -->
          <% if user_signed_in? && current_user != @property.user %>
            <% unless @property.reviews.exists?(user: current_user) %>
              <div class="bg-blue-50 rounded-lg p-6 mb-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Write a Review</h3>
                <%= form_with(model: Review.new, url: property_reviews_path(@property), class: "space-y-4") do |f| %>
                  <div>
                    <%= f.label :rating, "Rating", class: "block text-gray-700 font-semibold mb-2" %>
                    <div class="flex gap-2">
                      <% (1..5).each do |i| %>
                        <label class="cursor-pointer">
                          <%= f.radio_button :rating, i, class: "hidden peer" %>
                          <span class="text-3xl peer-checked:text-yellow-500 text-gray-300 hover:text-yellow-400">★</span>
                        </label>
                      <% end %>
                    </div>
                  </div>

                  <div>
                    <%= f.label :comment, "Your Review", class: "block text-gray-700 font-semibold mb-2" %>
                    <%= f.text_area :comment, rows: 4, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "Share your experience..." %>
                  </div>

                  <%= f.submit "Submit Review", class: "bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 cursor-pointer" %>
                <% end %>
              </div>
            <% else %>
              <div class="bg-green-50 rounded-lg p-4 mb-6">
                <p class="text-green-800">✓ You have already reviewed this property</p>
              </div>
            <% end %>
          <% elsif user_signed_in? && current_user == @property.user %>
            <div class="bg-gray-50 rounded-lg p-4 mb-6">
              <p class="text-gray-600">You cannot review your own property</p>
            </div>
          <% else %>
            <div class="bg-blue-50 rounded-lg p-4 mb-6">
              <p class="text-blue-800"><%= link_to "Sign in", new_user_session_path, class: "underline font-semibold" %> to write a review</p>
            </div>
          <% end %>
          
          <!-- Existing Reviews -->
          <% if @reviews.any? %>
            <div class="space-y-6 mt-6">
              <% @reviews.each do |review| %>
                <div class="border-b pb-6 last:border-b-0">
                  <div class="flex justify-between items-start mb-2">
                    <div>
                      <p class="font-semibold text-gray-900"><%= review.user.name || review.user.email %></p>
                      <p class="text-sm text-gray-500"><%= time_ago_in_words(review.created_at) %> ago</p>
                    </div>
                    <div class="flex items-center">
                      <span class="text-yellow-500">★</span>
                      <span class="font-bold ml-1"><%= review.rating %>/5</span>
                    </div>
                  </div>
                  <p class="text-gray-700"><%= review.comment %></p>
                  <% if user_signed_in? && review.user == current_user %>
                    <%= button_to "Delete", property_review_path(@property, review), method: :delete, class: "text-sm text-red-600 hover:text-red-800 mt-2", data: { turbo_confirm: "Are you sure?" } %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 text-center py-8">No reviews yet. Be the first to review!</p>
          <% end %>
        </div>

        <!-- Inquiries Section -->
        <% if user_signed_in? %>
          <% if current_user.customer? %>
            <!-- Customer: Send Inquiry Form -->
            <div class="mt-8">
              <%= render 'inquiries/form' %>
            </div>
          <% elsif current_user == @property.user && @inquiries.present? %>
            <!-- Property Owner: View Inquiries -->
            <div class="bg-white rounded-xl shadow-md p-8 mt-8">
              <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-bold text-gray-900">Property Inquiries (<%= @inquiries.count %>)</h2>
                <%= link_to property_inquiries_path(@property), class: "text-primary-600 hover:text-primary-700 font-medium" do %>
                  View All →
                <% end %>
              </div>

              <!-- Recent Inquiries -->
              <div class="space-y-4">
                <% @inquiries.limit(3).each do |inquiry| %>
                  <div class="border border-gray-200 rounded-lg p-4 hover:bg-gray-50 transition">
                    <div class="flex items-start justify-between mb-2">
                      <div class="flex items-center gap-2">
                        <div class="bg-primary-100 rounded-full p-2">
                          <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                          </svg>
                        </div>
                        <div>
                          <p class="font-semibold text-gray-900"><%= inquiry.customer.name %></p>
                          <p class="text-xs text-gray-500"><%= time_ago_in_words(inquiry.created_at) %> ago</p>
                        </div>
                      </div>
                      
                      <% case inquiry.status %>
                      <% when 'pending' %>
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                          Pending
                        </span>
                      <% when 'responded' %>
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                          Responded
                        </span>
                      <% when 'closed' %>
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                          Closed
                        </span>
                      <% end %>
                    </div>
                    
                    <p class="text-sm text-gray-700 line-clamp-2 mb-2"><%= inquiry.message %></p>
                    
                    <%= link_to inquiry_path(inquiry), class: "text-sm text-primary-600 hover:text-primary-700 font-medium" do %>
                      View Details →
                    <% end %>
                  </div>
                <% end %>
              </div>

              <% if @inquiries.count > 3 %>
                <div class="mt-6 text-center">
                  <%= link_to property_inquiries_path(@property), class: "btn btn-outline" do %>
                    View All <%= @inquiries.count %> Inquiries
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <!-- Price Card -->
        <div class="bg-white rounded-xl shadow-md p-6 mb-6 sticky top-20">
          <div class="text-center mb-6">
            <p class="text-gray-600 mb-2">Price</p>
            <p class="text-4xl font-extrabold text-primary-600">
              ₹<%= number_with_delimiter(@property.price) %>
            </p>
          </div>

          <div class="border-t pt-6 mb-6">
            <h3 class="font-bold text-gray-900 mb-4">Owner Details</h3>
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mr-3">
                <span class="text-2xl">👤</span>
              </div>
              <div>
                <p class="font-semibold text-gray-900"><%= @property.user.name || 'Property Owner' %></p>
                <p class="text-sm text-gray-500">Owner</p>
              </div>
            </div>
          </div>

          <% if user_signed_in? %>
            <% if current_user == @property.user %>
              <div class="space-y-3">
                <%= link_to "Edit Property", edit_property_path(@property), class: "btn btn-primary w-full" %>
                <%= button_to "Delete Property", 
                    property_path(@property), 
                    method: :delete,
                    data: { turbo_confirm: "Are you sure you want to delete this property?" },
                    class: "btn btn-secondary w-full" %>
              </div>
            <% else %>
              <div class="space-y-3">
                <%= link_to "📧 Contact Owner", new_property_message_path(@property), class: "btn btn-primary w-full" %>
                
                <% if favorited?(@property) %>
                  <% favorite = favorite_for(@property) %>
                  <%= button_to "❤️ Remove from Favorites", favorite_path(favorite), method: :delete, class: "btn btn-outline w-full bg-red-50 text-red-600 hover:bg-red-100" %>
                <% else %>
                  <%= button_to "🤍 Add to Favorites", favorites_path(property_id: @property.id), method: :post, class: "btn btn-outline w-full" %>
                <% end %>

                <% if in_comparison?(@property) %>
                  <%= button_to "✓ In Comparison", comparison_path(@property.id), method: :delete, class: "btn btn-outline w-full bg-blue-50" %>
                <% else %>
                  <%= button_to "⚖️ Add to Compare", comparisons_path(property_id: @property.id), method: :post, class: "btn btn-outline w-full" %>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div class="space-y-3">
              <%= link_to "Sign In to Contact", new_user_session_path, class: "btn btn-primary w-full" %>
              <%= button_to "⚖️ Add to Compare", comparisons_path(property_id: @property.id), method: :post, class: "btn btn-outline w-full" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

