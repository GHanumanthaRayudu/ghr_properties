<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Page Header -->
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Property Inquiries</h1>
        <p class="mt-2 text-gray-600">
          <%= link_to @property.title, @property, class: "text-primary-600 hover:text-primary-700 font-medium" %>
        </p>
      </div>
      <%= link_to @property, class: "btn btn-secondary" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Property
      <% end %>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-yellow-500">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600">Pending</p>
          <p class="text-2xl font-bold text-gray-900"><%= @inquiries.pending.count %></p>
        </div>
        <div class="bg-yellow-100 rounded-full p-3">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-blue-500">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600">Responded</p>
          <p class="text-2xl font-bold text-gray-900"><%= @inquiries.responded.count %></p>
        </div>
        <div class="bg-blue-100 rounded-full p-3">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-green-500">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600">Closed</p>
          <p class="text-2xl font-bold text-gray-900"><%= @inquiries.closed.count %></p>
        </div>
        <div class="bg-green-100 rounded-full p-3">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Inquiries List -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <h2 class="text-lg font-semibold text-gray-900">All Inquiries (<%= @inquiries.count %>)</h2>
    </div>

    <% if @inquiries.any? %>
      <div class="divide-y divide-gray-200">
        <% @inquiries.each do |inquiry| %>
          <div class="p-6 hover:bg-gray-50 transition">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <!-- Customer Info -->
                <div class="flex items-center gap-3 mb-3">
                  <div class="bg-primary-100 rounded-full p-2">
                    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900"><%= inquiry.customer.name %></p>
                    <p class="text-sm text-gray-500"><%= inquiry.customer.email %></p>
                  </div>
                </div>

                <!-- Message -->
                <div class="bg-gray-50 rounded-lg p-4 mb-3">
                  <p class="text-gray-700"><%= inquiry.message %></p>
                </div>

                <!-- Metadata -->
                <div class="flex items-center gap-4 text-sm text-gray-500">
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <%= time_ago_in_words(inquiry.created_at) %> ago
                  </span>
                  <span>•</span>
                  <span>ID: #<%= inquiry.id %></span>
                </div>
              </div>

              <!-- Status & Actions -->
              <div class="ml-6 flex flex-col items-end gap-3">
                <!-- Status Badge -->
                <% case inquiry.status %>
                <% when 'pending' %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                    <span class="w-2 h-2 bg-yellow-400 rounded-full mr-2"></span>
                    Pending
                  </span>
                <% when 'responded' %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                    <span class="w-2 h-2 bg-blue-400 rounded-full mr-2"></span>
                    Responded
                  </span>
                <% when 'closed' %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                    <span class="w-2 h-2 bg-green-400 rounded-full mr-2"></span>
                    Closed
                  </span>
                <% end %>

                <!-- Update Status -->
                <%= form_with model: inquiry, url: inquiry_path(inquiry), method: :patch, local: true do |f| %>
                  <div class="flex items-center gap-2">
                    <%= f.select :status, 
                        Inquiry.statuses.keys.map { |s| [s.titleize, s] }, 
                        { selected: inquiry.status },
                        class: "px-3 py-1 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
                    <%= f.submit "Update", class: "btn btn-sm btn-primary" %>
                  </div>
                <% end %>

                <!-- View Details -->
                <%= link_to inquiry_path(inquiry), class: "text-primary-600 hover:text-primary-700 text-sm font-medium" do %>
                  View Details →
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No inquiries yet</h3>
        <p class="mt-1 text-sm text-gray-500">This property hasn't received any inquiries yet.</p>
      </div>
    <% end %>
  </div>
</div>


