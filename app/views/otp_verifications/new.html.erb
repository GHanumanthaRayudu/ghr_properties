<% content_for :title, "Verify Phone Number - GHR Properties" %>

<div class="min-h-screen bg-gradient-to-br from-blue-600 to-indigo-800 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full bg-white rounded-2xl shadow-2xl p-8">
    <!-- Header -->
    <div class="text-center mb-8">
      <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-blue-100 mb-4">
        <svg class="h-10 w-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
        </svg>
      </div>
      <h2 class="text-3xl font-extrabold text-gray-900">Verify Your Phone</h2>
      <p class="mt-2 text-sm text-gray-600">
        We've sent a 6-digit OTP to
      </p>
      <p class="text-lg font-semibold text-blue-600 mt-1">
        +91 <%= @user.phone_number %>
      </p>
    </div>

    <!-- OTP Form -->
    <%= form_with url: otp_verification_path, method: :post, html: { class: "space-y-6" } do |f| %>
      <div>
        <%= f.label :otp_code, "Enter OTP", class: "form-label text-center block" %>
        <%= f.text_field :otp_code, 
            autofocus: true,
            maxlength: 6,
            pattern: "[0-9]{6}",
            placeholder: "000000",
            class: "form-input text-center text-2xl font-bold tracking-widest",
            required: true,
            autocomplete: "off" %>
        <p class="mt-2 text-xs text-gray-500 text-center">
          OTP is valid for 10 minutes
        </p>
      </div>

      <!-- Timer and Attempts -->
      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-yellow-700">
              <% if @user.otp_attempts > 0 %>
                ⚠️ <%= 3 - @user.otp_attempts %> attempts remaining
              <% else %>
                You have 3 attempts to enter the correct OTP
              <% end %>
            </p>
          </div>
        </div>
      </div>

      <!-- Submit Button -->
      <div>
        <%= f.submit "Verify OTP", class: "btn btn-primary w-full py-3 text-lg" %>
      </div>
    <% end %>

    <!-- Resend OTP -->
    <div class="mt-6">
      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white text-gray-500">Didn't receive the OTP?</span>
        </div>
      </div>

      <div class="mt-6 text-center">
        <% if @user.can_resend_otp? %>
          <%= button_to "Resend OTP", resend_otp_verification_path, method: :post, class: "font-medium text-blue-600 hover:text-blue-500 transition", data: { turbo: false } %>
        <% else %>
          <p class="text-sm text-gray-500">
            Please wait 1 minute before requesting a new OTP
          </p>
        <% end %>
      </div>
    </div>

    <!-- Help Text -->
    <div class="mt-8 bg-blue-50 rounded-lg p-4">
      <h3 class="text-sm font-medium text-blue-800 mb-2">💡 Tips:</h3>
      <ul class="text-xs text-blue-700 space-y-1">
        <li>• Check your phone's message inbox</li>
        <li>• OTP expires in 10 minutes</li>
        <li>• Make sure you entered the correct phone number</li>
        <li>• Contact support if you don't receive the OTP</li>
      </ul>
    </div>

    <!-- Sign Out Option -->
    <div class="mt-6 text-center">
      <p class="text-xs text-gray-500">
        Wrong number? 
        <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-blue-600 hover:text-blue-500 font-medium" %>
        and try again
      </p>
    </div>
  </div>
</div>

<script>
  // Auto-format OTP input
  document.addEventListener('DOMContentLoaded', function() {
    const otpInput = document.getElementById('otp_code');
    
    if (otpInput) {
      otpInput.addEventListener('input', function(e) {
        // Only allow numbers
        this.value = this.value.replace(/[^0-9]/g, '');
      });
      
      // Auto-submit when 6 digits are entered
      otpInput.addEventListener('keyup', function(e) {
        if (this.value.length === 6) {
          // You can uncomment this to auto-submit
          // this.form.submit();
        }
      });
    }
  });
</script>

