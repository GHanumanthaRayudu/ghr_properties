<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-pink-50 py-12">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <div class="inline-block mb-4">
        <span class="text-6xl">⚖️</span>
      </div>
      <h1 class="text-4xl font-extrabold text-gray-900 mb-3">Compare Properties</h1>
      <p class="text-lg text-gray-600">Side-by-side comparison to help you decide</p>
    </div>

  <% if @properties.any? %>
    <div class="mb-6 text-center">
      <%= button_to clear_comparisons_path, method: :delete, class: "inline-flex items-center gap-2 bg-red-500 text-white px-6 py-3 rounded-xl font-semibold hover:bg-red-600 hover:shadow-lg transition-all duration-200", data: { turbo_confirm: "Clear all properties from comparison?" } do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        <span>Clear All</span>
      <% end %>
    </div>
    <div class="overflow-x-auto bg-white rounded-2xl shadow-2xl">
      <table class="w-full">
        <thead class="bg-gradient-to-r from-blue-500 to-purple-500 text-white">
          <tr>
            <th class="px-6 py-5 text-left font-bold text-lg sticky left-0 bg-gradient-to-r from-blue-500 to-purple-500">Features</th>
            <% @properties.each do |property| %>
              <th class="px-6 py-5 text-center font-bold">
                <div class="mb-2">
                  <%= link_to property.title, property_path(property), class: "text-white hover:text-blue-100 font-bold text-lg block mb-2" %>
                </div>
                <%= button_to comparison_path(property.id), method: :delete, class: "inline-flex items-center gap-1 bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded-lg text-sm transition", title: "Remove" do %>
                  <span>Remove</span>
                  <span>×</span>
                <% end %>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <!-- Property Type -->
          <tr class="hover:bg-blue-50 transition">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-white">🏠 Property Type</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <span class="inline-flex items-center gap-1 px-4 py-2 rounded-full text-sm font-bold bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-md">
                  <%= property.property_type.capitalize %>
                </span>
              </td>
            <% end %>
          </tr>

          <!-- Listing Type -->
          <tr class="hover:bg-green-50 transition">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-white">🏷️ Listing Type</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <span class="inline-flex items-center gap-1 px-4 py-2 rounded-full text-sm font-bold bg-gradient-to-r from-green-500 to-green-600 text-white shadow-md">
                  For <%= property.listing_type.capitalize %>
                </span>
              </td>
            <% end %>
          </tr>

          <!-- Price -->
          <tr class="hover:bg-yellow-50 transition bg-blue-50">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-blue-50">💰 Price</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <div class="text-3xl font-extrabold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                  ₹<%= number_with_delimiter(property.price) %>
                </div>
              </td>
            <% end %>
          </tr>

          <!-- Bedrooms -->
          <tr class="hover:bg-purple-50 transition">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-white">🛏️ Bedrooms</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <span class="text-2xl font-bold text-gray-900"><%= property.bedrooms %></span>
              </td>
            <% end %>
          </tr>

          <!-- Bathrooms -->
          <tr class="hover:bg-blue-50 transition">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-white">🚿 Bathrooms</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <span class="text-2xl font-bold text-gray-900"><%= property.bathrooms %></span>
              </td>
            <% end %>
          </tr>

          <!-- Area -->
          <tr class="hover:bg-green-50 transition bg-gray-50">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-gray-50">📐 Area</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <div class="font-bold text-xl text-gray-900"><%= number_with_delimiter(property.area) %></div>
                <div class="text-sm text-gray-500">sqft</div>
              </td>
            <% end %>
          </tr>

          <!-- Location -->
          <tr class="hover:bg-indigo-50 transition">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-white">📍 Location</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <div class="inline-flex items-center gap-1 bg-blue-100 text-blue-800 px-4 py-2 rounded-full font-semibold">
                  <%= property.city %>, <%= property.state %>
                </div>
              </td>
            <% end %>
          </tr>

          <!-- Rating -->
          <tr class="hover:bg-yellow-50 transition bg-yellow-50">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-yellow-50">⭐ Rating</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <% if property.reviews.any? %>
                  <div class="inline-flex items-center gap-2 bg-yellow-100 px-4 py-2 rounded-full">
                    <span class="text-yellow-500 text-2xl">★</span>
                    <span class="font-bold text-xl text-gray-900"><%= property.average_rating %></span>
                    <span class="text-sm text-gray-600">(<%= property.reviews_count %>)</span>
                  </div>
                <% else %>
                  <span class="text-gray-400 text-sm">No reviews</span>
                <% end %>
              </td>
            <% end %>
          </tr>

          <!-- Amenities -->
          <tr class="hover:bg-pink-50 transition bg-gray-50">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-gray-50">✨ Amenities</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <% if property.amenities.present? %>
                  <div class="text-sm text-gray-700 max-h-32 overflow-y-auto bg-white px-3 py-2 rounded-lg">
                    <%= property.amenities %>
                  </div>
                <% else %>
                  <span class="text-gray-400 text-sm">Not specified</span>
                <% end %>
              </td>
            <% end %>
          </tr>

          <!-- Owner -->
          <tr class="hover:bg-purple-50 transition">
            <td class="px-6 py-5 font-bold text-gray-800 sticky left-0 bg-white">👤 Owner</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-5 text-center">
                <div class="inline-flex items-center gap-2 bg-purple-100 text-purple-800 px-4 py-2 rounded-full font-semibold">
                  <%= property.user.name %>
                </div>
              </td>
            <% end %>
          </tr>

          <!-- Actions -->
          <tr class="bg-gradient-to-r from-blue-50 to-purple-50">
            <td class="px-6 py-6 font-bold text-gray-800 sticky left-0 bg-gradient-to-r from-blue-50 to-purple-50">🎯 Actions</td>
            <% @properties.each do |property| %>
              <td class="px-6 py-6 text-center">
                <div class="flex flex-col gap-2">
                  <%= link_to property_path(property), class: "inline-flex items-center justify-center gap-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white px-4 py-3 rounded-xl font-semibold hover:shadow-lg transform hover:scale-105 transition-all duration-200" do %>
                    <span>View Details</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  <% end %>
                  <% if user_signed_in? %>
                    <%= link_to new_property_message_path(property), class: "inline-flex items-center justify-center gap-2 bg-gradient-to-r from-green-500 to-green-600 text-white px-4 py-3 rounded-xl font-semibold hover:shadow-lg transform hover:scale-105 transition-all duration-200" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                      </svg>
                      <span>Contact</span>
                    <% end %>
                  <% end %>
                </div>
              </td>
            <% end %>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="mt-10 text-center">
      <%= link_to properties_path, class: "inline-flex items-center gap-2 bg-white text-gray-700 px-8 py-4 rounded-xl font-semibold shadow-lg hover:shadow-xl transition-all duration-200" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        <span>Browse More Properties</span>
      <% end %>
    </div>
  <% else %>
    <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-2xl p-16 text-center">
      <div class="mb-6">
        <span class="text-8xl">🤷</span>
      </div>
      <h3 class="text-3xl font-bold text-gray-900 mb-4">No Properties to Compare</h3>
      <p class="text-lg text-gray-600 mb-8">Add properties to your comparison list to see them side by side and make better decisions!</p>
      <div class="bg-blue-50 rounded-xl p-6 mb-8">
        <h4 class="font-bold text-gray-900 mb-3">💡 How to Compare</h4>
        <ol class="text-left text-gray-700 space-y-2 max-w-md mx-auto">
          <li class="flex items-start gap-2">
            <span class="font-bold text-blue-600">1.</span>
            <span>Browse properties and click "Add to Compare"</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-bold text-blue-600">2.</span>
            <span>Add up to 4 properties</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-bold text-blue-600">3.</span>
            <span>Come back here to see the comparison</span>
          </li>
        </ol>
      </div>
      <%= link_to properties_path, class: "inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white px-10 py-5 rounded-xl font-bold text-lg hover:shadow-2xl transform hover:scale-105 transition-all duration-200" do %>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span>Browse Properties</span>
      <% end %>
    </div>
  <% end %>
  </div>
</div>

