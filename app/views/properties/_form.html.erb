<div class="bg-white rounded-xl shadow-md p-8">
  <%= form_with(model: property, class: "space-y-6") do |form| %>
    <% if property.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-lg">
        <h3 class="text-red-800 font-bold mb-2"><%= pluralize(property.errors.count, "error") %> prohibited this property from being saved:</h3>
        <ul class="list-disc list-inside text-red-700 text-sm">
          <% property.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Basic Information -->
    <div>
      <h3 class="text-xl font-bold text-gray-900 mb-4">Basic Information</h3>
      
      <div class="space-y-4">
        <div>
          <%= form.label :title, class: "form-label" %>
          <%= form.text_field :title, 
              placeholder: "e.g., Spacious 3BHK Apartment in Mumbai",
              class: "form-input" %>
        </div>

        <div>
          <%= form.label :description, class: "form-label" %>
          <%= form.text_area :description,
              rows: 6,
              placeholder: "Describe your property in detail...",
              class: "form-input" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :property_type, class: "form-label" %>
            <%= form.select :property_type,
                [['House', 'house'], ['Apartment', 'apartment'], ['Condo', 'condo'], ['Land', 'land'], ['Commercial', 'commercial']],
                { include_blank: 'Select type' },
                class: "form-input" %>
          </div>

          <div>
            <%= form.label :status, class: "form-label" %>
            <%= form.select :status,
                [['Available', 'available'], ['Sold', 'sold'], ['Ongoing', 'ongoing'], ['Rented', 'rented']],
                { include_blank: 'Select status' },
                class: "form-input" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Property Details -->
    <div class="pt-6 border-t">
      <h3 class="text-xl font-bold text-gray-900 mb-4">Property Details</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <%= form.label :bedrooms, "Bedrooms (BHK)", class: "form-label" %>
          <%= form.number_field :bedrooms,
              min: 1,
              class: "form-input" %>
        </div>

        <div>
          <%= form.label :bathrooms, class: "form-label" %>
          <%= form.number_field :bathrooms,
              min: 1,
              class: "form-input" %>
        </div>

        <div>
          <%= form.label :area, "Area (sq.ft)", class: "form-label" %>
          <%= form.number_field :area,
              min: 100,
              class: "form-input" %>
        </div>
      </div>
    </div>

    <!-- Location -->
    <div class="pt-6 border-t">
      <h3 class="text-xl font-bold text-gray-900 mb-4">Location</h3>
      
      <div class="space-y-4">
        <div>
          <%= form.label :address, class: "form-label" %>
          <%= form.text_field :address,
              placeholder: "Street address",
              class: "form-input" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <%= form.label :city, class: "form-label" %>
            <%= form.text_field :city, class: "form-input" %>
          </div>

          <div>
            <%= form.label :state, class: "form-label" %>
            <%= form.text_field :state, class: "form-input" %>
          </div>

          <div>
            <%= form.label :pincode, class: "form-label" %>
            <%= form.text_field :pincode, class: "form-input" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Price and Availability -->
    <div class="pt-6 border-t">
      <h3 class="text-xl font-bold text-gray-900 mb-4">Price & Availability</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= form.label :price, "Price (₹)", class: "form-label" %>
          <%= form.number_field :price,
              min: 0,
              step: 1000,
              class: "form-input" %>
          <p class="text-sm text-gray-500 mt-1">
            Enter monthly rent or total sale price
          </p>
        </div>

        <div>
          <%= form.label :available_from, class: "form-label" %>
          <%= form.date_field :available_from, class: "form-input" %>
        </div>
      </div>
    </div>

    <!-- Amenities -->
    <div class="pt-6 border-t">
      <h3 class="text-xl font-bold text-gray-900 mb-4">Amenities</h3>
      <%= form.text_area :amenities,
          rows: 3,
          placeholder: "Parking, Gym, Swimming Pool, Security, Power Backup (comma separated)",
          class: "form-input" %>
      <p class="text-sm text-gray-500 mt-1">
        Enter amenities separated by commas
      </p>
    </div>

    <!-- Submit Button -->
    <div class="pt-6 border-t flex justify-end space-x-4">
      <%= link_to "Cancel", properties_path, class: "btn btn-secondary" %>
      <%= form.submit class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

