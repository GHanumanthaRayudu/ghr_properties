<% content_for :title, "GHR Properties - Find Your Dream Property Without Broker Fees" %>

<!-- Hero Section -->
<div class="relative bg-gradient-to-br from-primary-600 to-primary-800 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold mb-6">
        Find Your Dream Property
        <span class="block text-primary-200">Without Broker Fees</span>
      </h1>
      <p class="text-xl md:text-2xl mb-8 text-primary-100 max-w-3xl mx-auto">
        Buy, Rent, or Sell properties directly with owners. Save thousands in brokerage fees.
      </p>
      
      <!-- Search Bar -->
      <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-2xl p-6">
        <%= form_with url: properties_path, method: :get, class: "space-y-4" do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <%= f.select :status, 
                  options_for_select([
                    ['Available', 'available'],
                    ['Sold', 'sold'],
                    ['Ongoing', 'ongoing'],
                    ['Rented', 'rented']
                  ], params[:status]),
                  { include_blank: 'Property Status' },
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-700 focus:ring-2 focus:ring-primary-500" %>
            </div>
            
            <div>
              <%= f.select :property_type,
                  options_for_select([
                    ['House', 'house'],
                    ['Apartment', 'apartment'],
                    ['Condo', 'condo'],
                    ['Land', 'land'],
                    ['Commercial', 'commercial']
                  ], params[:property_type]),
                  { include_blank: 'Property Type' },
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-700 focus:ring-2 focus:ring-primary-500" %>
            </div>
            
            <div>
              <%= f.text_field :location, 
                  value: params[:location],
                  placeholder: "City or Location",
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-700 focus:ring-2 focus:ring-primary-500" %>
            </div>
          </div>
          
          <div class="flex justify-center">
            <%= f.submit "Search Properties", class: "btn btn-primary px-8 py-3 text-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<div class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-gray-900 mb-4">Why Choose GHR Properties?</h2>
      <p class="text-lg text-gray-600">Your trusted platform for direct property transactions</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="text-center p-6 bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl">
        <div class="text-5xl mb-4">💰</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Zero Brokerage</h3>
        <p class="text-gray-600">Save thousands by dealing directly with owners</p>
      </div>
      
      <div class="text-center p-6 bg-gradient-to-br from-green-50 to-green-100 rounded-xl">
        <div class="text-5xl mb-4">✅</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Verified Listings</h3>
        <p class="text-gray-600">All properties are verified for authenticity</p>
      </div>
      
      <div class="text-center p-6 bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl">
        <div class="text-5xl mb-4">🔒</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Secure Transactions</h3>
        <p class="text-gray-600">Your data and transactions are completely secure</p>
      </div>
      
      <div class="text-center p-6 bg-gradient-to-br from-orange-50 to-orange-100 rounded-xl">
        <div class="text-5xl mb-4">⚡</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Quick & Easy</h3>
        <p class="text-gray-600">Find your property in minutes, not months</p>
      </div>
    </div>
  </div>
</div>

<!-- Latest Properties -->
<div class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-3xl font-extrabold text-gray-900">Latest Properties</h2>
      <%= link_to "View All Properties →", properties_path, class: "text-primary-600 hover:text-primary-700 font-semibold" %>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% Property.order(created_at: :desc).limit(6).each do |property| %>
        <%= link_to property_path(property), class: "card" do %>
          <div class="h-48 bg-gradient-to-br from-gray-300 to-gray-400 flex items-center justify-center">
            <span class="text-6xl"><%= property.property_type == 'apartment' ? '🏢' : '🏠' %></span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900 mb-2"><%= property.title %></h3>
            <p class="text-gray-600 mb-2">
              <span class="inline-block mr-2">📍</span>
              <%= property.city %>, <%= property.state %>
            </p>
            <div class="flex justify-between items-center mt-4">
              <span class="text-2xl font-bold text-primary-600">
                ₹<%= number_with_delimiter(property.price) %>
              </span>
              <span class="px-3 py-1 <%= property.available? ? 'bg-green-100 text-green-800' : property.sold? ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' %> rounded-full text-sm font-semibold">
                <%= property.status.titleize %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- CTA Section -->
<div class="bg-gradient-to-r from-primary-600 to-primary-800 text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-extrabold mb-4">Ready to Find Your Perfect Property?</h2>
    <p class="text-xl mb-8 text-primary-100">Join thousands of happy customers who found their dream homes</p>
    <div class="flex justify-center space-x-4">
      <% if user_signed_in? %>
        <%= link_to "Browse Properties", properties_path, class: "btn bg-white text-primary-600 hover:bg-gray-100 px-8 py-3 text-lg" %>
        <%= link_to "Post Your Property", new_property_path, class: "btn btn-outline border-white text-white hover:bg-white hover:text-primary-600 px-8 py-3 text-lg" %>
      <% else %>
        <%= link_to "Get Started", new_user_registration_path, class: "btn bg-white text-primary-600 hover:bg-gray-100 px-8 py-3 text-lg" %>
        <%= link_to "Browse Properties", properties_path, class: "btn btn-outline border-white text-white hover:bg-white hover:text-primary-600 px-8 py-3 text-lg" %>
      <% end %>
    </div>
  </div>
</div>
