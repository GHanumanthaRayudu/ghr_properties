<div class="min-h-screen bg-gradient-to-br from-purple-50 via-white to-blue-50">
  <div class="container mx-auto px-4 py-12">
    <div class="mb-10 text-center">
      <div class="inline-block mb-4">
        <span class="text-6xl">💬</span>
      </div>
      <h1 class="text-4xl font-extrabold text-gray-900 mb-3">Messages</h1>
      <p class="text-lg text-gray-600">Stay connected with property owners</p>
    </div>

  <div class="flex gap-3 mb-8 justify-center">
    <button onclick="showTab('received')" id="received-tab" class="px-8 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl font-semibold shadow-lg transform transition-all duration-200">
      📥 Received (<%= @received_messages.count %>)
    </button>
    <button onclick="showTab('sent')" id="sent-tab" class="px-8 py-3 bg-white text-gray-700 rounded-xl font-semibold shadow-md hover:shadow-lg transition-all duration-200">
      📤 Sent (<%= @sent_messages.count %>)
    </button>
  </div>

  <!-- Received Messages -->
  <div id="received-messages" class="max-w-4xl mx-auto">
    <% if @received_messages.any? %>
      <div class="space-y-4">
        <% @received_messages.each do |message| %>
          <div class="bg-white rounded-2xl shadow-lg p-6 hover:shadow-2xl transition-all duration-300 border-l-4 border-blue-500">
            <div class="flex justify-between items-start mb-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-2xl">👤</span>
                  <div>
                    <h3 class="text-lg font-bold text-gray-900">
                      <%= message.subject || "Property Inquiry" %>
                    </h3>
                    <p class="text-sm text-gray-600">
                      From: <span class="font-semibold text-blue-600"><%= message.sender.name %></span> 
                      <span class="text-gray-400">•</span>
                      <span class="text-gray-500"><%= time_ago_in_words(message.created_at) %> ago</span>
                    </p>
                  </div>
                </div>
              </div>
              <%= link_to property_path(message.property), class: "inline-flex items-center gap-1 text-sm text-blue-600 hover:text-blue-800 font-medium bg-blue-50 px-3 py-2 rounded-lg hover:bg-blue-100 transition" do %>
                <span>View Property</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              <% end %>
            </div>
            
            <div class="bg-gray-50 rounded-lg p-4 mb-4">
              <p class="text-gray-700 leading-relaxed"><%= message.content %></p>
            </div>
            
            <div class="flex items-center gap-2 text-xs text-gray-500 mb-3 bg-blue-50 px-3 py-2 rounded-lg">
              <span>🏠</span>
              <span class="font-medium"><%= message.property.title %></span>
            </div>
            
            <%= link_to new_property_message_path(message.property), class: "inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white px-6 py-3 rounded-xl font-semibold hover:shadow-lg transform hover:scale-105 transition-all duration-200" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
              </svg>
              <span>Reply</span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-2xl shadow-xl p-12 text-center">
        <span class="text-6xl mb-4 block">📭</span>
        <h3 class="text-xl font-bold text-gray-900 mb-2">No messages yet</h3>
        <p class="text-gray-500">Your inbox is empty</p>
      </div>
    <% end %>
  </div>

  <!-- Sent Messages -->
  <div id="sent-messages" class="max-w-4xl mx-auto hidden">
    <% if @sent_messages.any? %>
      <div class="space-y-4">
        <% @sent_messages.each do |message| %>
          <div class="bg-white rounded-2xl shadow-lg p-6 hover:shadow-2xl transition-all duration-300 border-l-4 border-purple-500">
            <div class="flex justify-between items-start mb-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-2xl">📤</span>
                  <div>
                    <h3 class="text-lg font-bold text-gray-900">
                      <%= message.subject || "Property Inquiry" %>
                    </h3>
                    <p class="text-sm text-gray-600">
                      To: <span class="font-semibold text-purple-600"><%= message.receiver.name %></span> 
                      <span class="text-gray-400">•</span>
                      <span class="text-gray-500"><%= time_ago_in_words(message.created_at) %> ago</span>
                    </p>
                  </div>
                </div>
              </div>
              <%= link_to property_path(message.property), class: "inline-flex items-center gap-1 text-sm text-purple-600 hover:text-purple-800 font-medium bg-purple-50 px-3 py-2 rounded-lg hover:bg-purple-100 transition" do %>
                <span>View Property</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              <% end %>
            </div>
            
            <div class="bg-gray-50 rounded-lg p-4 mb-3">
              <p class="text-gray-700 leading-relaxed"><%= message.content %></p>
            </div>
            
            <div class="flex items-center gap-2 text-xs text-gray-500 bg-purple-50 px-3 py-2 rounded-lg">
              <span>🏠</span>
              <span class="font-medium"><%= message.property.title %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-2xl shadow-xl p-12 text-center">
        <span class="text-6xl mb-4 block">📬</span>
        <h3 class="text-xl font-bold text-gray-900 mb-2">No sent messages</h3>
        <p class="text-gray-500">You haven't sent any messages yet</p>
      </div>
    <% end %>
  </div>
  </div>
</div>

<script>
  function showTab(tab) {
    const receivedTab = document.getElementById('received-tab');
    const sentTab = document.getElementById('sent-tab');
    const receivedMessages = document.getElementById('received-messages');
    const sentMessages = document.getElementById('sent-messages');

    if (tab === 'received') {
      receivedTab.className = 'px-8 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl font-semibold shadow-lg transform transition-all duration-200';
      sentTab.className = 'px-8 py-3 bg-white text-gray-700 rounded-xl font-semibold shadow-md hover:shadow-lg transition-all duration-200';
      receivedMessages.classList.remove('hidden');
      sentMessages.classList.add('hidden');
    } else {
      receivedTab.className = 'px-8 py-3 bg-white text-gray-700 rounded-xl font-semibold shadow-md hover:shadow-lg transition-all duration-200';
      sentTab.className = 'px-8 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl font-semibold shadow-lg transform transition-all duration-200';
      receivedMessages.classList.add('hidden');
      sentMessages.classList.remove('hidden');
    }
  }
</script>

